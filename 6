numbers = [8, 9, 10, 11]

# Заменяем второй (по порядку) элемент списка на 17
numbers[1] = 17

# Добавляем числа 4, 5 и 6 в конец списка
numbers.extend([4, 5, 6])

# Удаляем первый (по порядку) элемент списка
numbers.pop(0)

# Удваиваем список
numbers = numbers * 2

# Вставляем число 25 по индексу 3
numbers.insert(3, 25)

print(numbers)
